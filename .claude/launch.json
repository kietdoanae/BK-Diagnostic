{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "BKDiagnostic Preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "C:/Users/KIET/AndroidStudioProjects/BKDiagnostic/website", "-p", "9091", "--no-clipboard"],
      "port": 9091
    },
    {
      "name": "Website Preview",
      "runtimeExecutable": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe",
      "runtimeArgs": [
        "-NoProfile", "-ExecutionPolicy", "Bypass",
        "-File", "C:/Users/KIET/AndroidStudioProjects/BKDiagnostic/serve_preview.ps1"
      ],
      "port": 9090
    },
    {
      "name": "Build Debug APK",
      "runtimeExecutable": "./gradlew",
      "runtimeArgs": ["assembleDebug", "--stacktrace"],
      "port": 0
    },
    {
      "name": "Install Debug (Device/Emulator)",
      "runtimeExecutable": "./gradlew",
      "runtimeArgs": ["installDebug"],
      "port": 0
    },
    {
      "name": "Run Unit Tests",
      "runtimeExecutable": "./gradlew",
      "runtimeArgs": ["test"],
      "port": 0
    },
    {
      "name": "Clean Build",
      "runtimeExecutable": "./gradlew",
      "runtimeArgs": ["clean", "assembleDebug"],
      "port": 0
    },
    {
      "name": "BK Diagnostic React Dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5173", "--host"],
      "port": 5173
    }
  ]
}
