<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Theme chính của app -->
    <style name="Theme.BKDiagnostic" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Theme cho system splash screen (Android 12+) -->
